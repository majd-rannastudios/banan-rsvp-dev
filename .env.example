# Supabase (Phase 2+) — from your Supabase project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Used only in team-invite and
# CSV-import server code (see lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=

# QR pass signing (Phase 3) — generate with: openssl rand -base64 32
QR_SIGNING_SECRET=

# Vercel Cron auth header for /api/cron/reminders (Phase 6)
CRON_SECRET=

# Messaging providers (Phase 6) — one of: mock | <real provider>
# Defaults to "mock" if unset, so a fresh environment never calls a real
# provider by accident. Swap independently per channel.
MESSAGING_WHATSAPP_PROVIDER=mock
MESSAGING_SMS_PROVIDER=mock
MESSAGING_EMAIL_PROVIDER=mock

# Real provider credentials — only read when the corresponding
# MESSAGING_*_PROVIDER above is set to a non-mock value.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM_NUMBER=

WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID=

RESEND_API_KEY=
RESEND_FROM_EMAIL=
